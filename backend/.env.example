# Application
NODE_ENV=development
PORT=3000
APP_NAME=CookMe API

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=cookme
DB_PASSWORD=cookme123
DB_DATABASE=cookme_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Redis (futuro)
REDIS_HOST=localhost
REDIS_PORT=6379

# External APIs (futuro)
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Python Microservice (futuro)
PYTHON_SERVICE_URL=http://localhost:5000
# OCR de cupom — provider configurável (haiku | gemini | auto)
OCR_PROVIDER=auto
OCR_PROVIDER_PRIMARY=haiku
# OCR_HAIKU_MODEL=claude-haiku-4-5-20251001
# OCR_GEMINI_MODEL=gemini-2.0-flash

# Engine de canonização (food-canonizer-api) — CookMe consome como cliente B2B via HTTP
# (ver PLANO_EXTRACAO_ENGINE.md Fase 5). Sem fallback local: Engine fora do ar = item fica
# "pendente" (EngineClientService), nunca derruba o fluxo do CookMe.
ENGINE_API_URL=http://localhost:3111
ENGINE_API_KEY=
